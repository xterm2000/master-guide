# Example node-IP maps. Two shapes show up across this repo's scripts —
# use whichever matches what a given script expects to `source`.

# NODES1: plain indexed array — for scripts that just loop over IPs
# (e.g. ssh-key-distribution.md, passwordless-sudo.md)
NODES1=(
  10.0.1.10
  10.0.1.11
  10.0.1.12
  10.0.1.13
  10.0.1.14
  10.0.1.15
  10.0.1.16
  10.0.1.17
  10.0.1.18
  10.0.1.19
  10.0.1.20
  10.0.1.21
)

# NODES2: associative array keyed by role — for scripts that need named lookup
# (e.g. reboot-machines.md)
declare -A NODES2
NODES2=(
  [control]="10.0.2.10"
  [worker-1]="10.0.2.11"
  [worker-2]="10.0.2.12"
  [worker-3]="10.0.2.13"
)

# A third shape — associative, keyed by role+number (control-1, worker-3, ...) —
# backs network/node-connect.md's connect.sh, which addresses a node by
# `<role> <number>` on the command line. See that file for its own nodes.env.
